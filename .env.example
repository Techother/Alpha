# ─────────────────────────────────────────────────────────────
# MKL Health — Environment Variables Reference
# ─────────────────────────────────────────────────────────────
# Copy to .env.local for local development (gitignored).
# Populate Vercel dashboard with these values (Production + Preview).
#
# VITE_ prefix = exposed to browser bundle (Supabase client only).
# All other vars = server-only (api/*.js Vercel functions).
# Never add VITE_ prefix to Airtable, Slack, GCal, Anthropic, or Twilio keys.
# ─────────────────────────────────────────────────────────────

# ── Supabase (browser-safe — used by Supabase JS client) ─────
# Project Settings > API in the Supabase dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase (server-only — service role for proxy JWT verification) ──
# Project Settings > API > service_role key (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# ── Airtable (server-only — api/proxy-airtable.js) ───────────
# https://airtable.com/account > API key
AIRTABLE_API_KEY=
# Your Airtable base ID (starts with "app")
AIRTABLE_BASE_ID=

# ── Slack (server-only — api/proxy-slack.js) ─────────────────
# https://api.slack.com/apps > OAuth & Permissions > Bot Token
SLACK_BOT_TOKEN=
# Default channel ID for alerts (e.g. C01234ABCDE — not the channel name)
SLACK_CHANNEL_ID=

# ── Google Calendar (server-only — api/proxy-gcal.js) ────────
# Full JSON content of the GCP service account key file
GCAL_SERVICE_ACCOUNT_JSON=
# Calendar ID to read/write (e.g. xxx@group.calendar.google.com)
GCAL_CALENDAR_ID=

# ── Anthropic (server-only — api/chat.js) ────────────────────
# https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# ── Twilio (server-only — api/send-sms.js) ───────────────────
# https://console.twilio.com > Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── CORS allowlist (server-only — api/_lib/auth.js) ──────────
# Your production Vercel URL (e.g. https://cardiotrack.vercel.app)
PRODUCTION_URL=
# VERCEL_URL is injected automatically by Vercel — do not add here.
