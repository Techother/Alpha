# Supabase — Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Airtable — https://airtable.com/account
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=

# Slack Bot Token — https://api.slack.com/apps > OAuth & Permissions
VITE_SLACK_BOT_TOKEN=
VITE_SLACK_CHANNEL_ID=

# Google Calendar OAuth 2.0 — https://console.cloud.google.com
VITE_GCAL_CLIENT_ID=
VITE_GCAL_API_KEY=

# Anthropic proxy URL (server-side only — never expose key in client)
VITE_ANTHROPIC_PROXY_URL=http://localhost:3001/api/chat

# Twilio (SMS check-ins)
# Note: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER (no VITE_ prefix)
# are used server-side in api/send-sms.js (Vercel serverless function)
VITE_TWILIO_ACCOUNT_SID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
